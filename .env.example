# GitHub personal access token used by @ht6/ingestion to read PRs/review comments (repo scope).
GITHUB_TOKEN=

# Directory where the interchange JSON files (raw-comments, episodes, conventions) are read/written.
DATA_DIR=./data

# Optional: used by @ht6/extraction (clustering) and @ht6/mcp-server (embeddings, LLM validation fallback).
ANTHROPIC_API_KEY=

# Optional dependency-free vector signal for Person 3 hybrid retrieval. Leave unset for lexical-only.
ENGINEERING_MEMORY_EMBEDDINGS=

# Merge-only GitHub webhook service. The same secret must be configured in repository settings.
GITHUB_WEBHOOK_SECRET=
WEBHOOK_HOST=127.0.0.1
WEBHOOK_PORT=8787
