# GitHub personal access token used by @ht6/ingestion to read PRs/review comments (repo scope).
GITHUB_TOKEN=

# Directory where the interchange JSON files (raw-comments, episodes, conventions) are read/written.
DATA_DIR=./data

# Optional: used by @ht6/extraction (clustering) and @ht6/mcp-server (embeddings, LLM validation fallback).
ANTHROPIC_API_KEY=

# Semantic extraction provider. Deterministic is local/free and remains the default.
# For a hosted deployment, keep these values on the backend; editor users should never receive
# the service key. FREESOLO_BASE_URL must include the OpenAI-compatible /v1 suffix.
ENGINEERING_MEMORY_SEMANTIC_ANALYZER=deterministic
ENGINEERING_MEMORY_SEMANTIC_FALLBACK=deterministic
FREESOLO_BASE_URL=
FREESOLO_MODEL=
FREESOLO_API_KEY=
FREESOLO_TIMEOUT_MS=15000
FREESOLO_MAX_RETRIES=2
FREESOLO_RETRY_DELAY_MS=250
FREESOLO_MAX_CONCURRENCY=4

# Optional dependency-free vector signal for Person 3 hybrid retrieval. Leave unset for lexical-only.
ENGINEERING_MEMORY_EMBEDDINGS=

# Merge-only GitHub webhook service. The same secret must be configured in repository settings.
GITHUB_WEBHOOK_SECRET=
WEBHOOK_HOST=127.0.0.1
WEBHOOK_PORT=8787

# Pre-commit review gate. Repository is inferred from origin unless explicitly set.
ENGINEERING_MEMORY_REPOSITORY=
ENGINEERING_MEMORY_BLOCK_THRESHOLD=0.8
ENGINEERING_MEMORY_BLOCK_MIN_SUPPORT=2
ENGINEERING_MEMORY_REQUIRE_DATA=false
