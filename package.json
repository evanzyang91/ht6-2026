{
  "name": "ht6-2026",
  "private": true,
  "version": "0.0.1",
  "description": "MCP server that gives coding agents memory of an organization's past PR review conventions.",
  "engines": {
    "node": ">=20"
  },
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "db:generate": "npm run db:generate --workspace=@ht6/extraction",
    "db:up": "docker compose up -d --wait db",
    "db:down": "docker compose down",
    "db:logs": "docker compose logs -f db",
    "db:migrate": "npm run db:migrate --workspace=@ht6/extraction",
    "db:setup": "npm run db:up && npm run db:migrate",
    "prebuild": "npm run db:generate",
    "build": "tsc -b",
    "pretypecheck": "npm run db:generate",
    "typecheck": "tsc -b --force",
    "test": "vitest run",
    "ingest": "npm run start --workspace=@ht6/ingestion --",
    "extract": "npm run start --workspace=@ht6/extraction --",
    "mcp-server": "npm run start --workspace=@ht6/mcp-server --",
    "api-server": "npm run start --workspace=@ht6/api-server --",
    "review-check": "tsx packages/mcp-server/src/precommit.ts",
    "hooks:install": "git config core.hooksPath .githooks",
    "webhook-server": "npm run start --workspace=@ht6/webhook-server --",
    "vscode:build": "npm run build --workspace=engineering-memory-vscode",
    "freesolo:mock-data": "node scripts/generate-freesolo-mock-data.mjs",
    "freesolo:build-dataset": "node scripts/generate-freesolo-mock-data.mjs",
    "freesolo:evaluate": "node scripts/evaluate-freesolo-run.mjs",
    "freesolo:check-response": "node scripts/check-freesolo-response.mjs"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsx": "^4.16.0",
    "typescript": "^5.5.0",
    "vitest": "^4.1.10"
  }
}
