# GraphQL endpoint for packages/api-server. When these are unset, the dashboard renders clearly
# labeled demo data so Vercel preview deployments remain usable.
ENGINEERING_MEMORY_API_URL=http://127.0.0.1:8790/graphql
ENGINEERING_MEMORY_REPOSITORY=owner/repository

# Server-only GitHub token. Never prefix this variable with NEXT_PUBLIC_.
ENGINEERING_MEMORY_GITHUB_TOKEN=
