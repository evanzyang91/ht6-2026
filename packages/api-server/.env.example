API_HOST=127.0.0.1
API_PORT=8790
DATA_DIR=../../data

# Extraction writer. In production this should be a dedicated pooled Supabase role.
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/engineering_memory?schema=public"

# Backend-only semantic extraction configuration. Do not expose provider keys to editor clients.
ENGINEERING_MEMORY_SEMANTIC_ANALYZER=deterministic
ENGINEERING_MEMORY_SEMANTIC_FALLBACK=deterministic
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
GEMINI_TIMEOUT_MS=30000
GEMINI_MAX_RETRIES=2
GEMINI_RETRY_DELAY_MS=250
GEMINI_MAX_CONCURRENCY=4
FREESOLO_BASE_URL=
FREESOLO_MODEL=
FREESOLO_API_KEY=
FREESOLO_TIMEOUT_MS=15000
FREESOLO_MAX_RETRIES=2
FREESOLO_RETRY_DELAY_MS=250
FREESOLO_MAX_CONCURRENCY=4

# Retrieval reader. Use a separate read-only role in production; local dev can reuse the writer.
DATABASE_READ_URL="postgresql://postgres:postgres@localhost:5432/engineering_memory?schema=public"
