# Extraction is the only pipeline stage that needs this credential.
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/engineering_memory?schema=public"

# Prisma CLI/migrations bypass a production pooler. This can equal DATABASE_URL locally.
DIRECT_URL="postgresql://postgres:postgres@localhost:5432/engineering_memory?schema=public"

# Optional hosted semantic analyzer. Leave deterministic for a local/offline extraction.
ENGINEERING_MEMORY_SEMANTIC_ANALYZER=deterministic
ENGINEERING_MEMORY_SEMANTIC_FALLBACK=deterministic
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
GEMINI_TIMEOUT_MS=30000
GEMINI_MAX_RETRIES=2
GEMINI_RETRY_DELAY_MS=250
GEMINI_MAX_CONCURRENCY=4
FREESOLO_BASE_URL=
FREESOLO_MODEL=
FREESOLO_API_KEY=
FREESOLO_TIMEOUT_MS=15000
FREESOLO_MAX_RETRIES=2
FREESOLO_RETRY_DELAY_MS=250
FREESOLO_MAX_CONCURRENCY=4
