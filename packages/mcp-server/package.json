{
  "name": "@ht6/mcp-server",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "main": "./dist/server.js",
  "exports": {
    ".": "./dist/server.js",
    "./api": {
      "types": "./dist/api.d.ts",
      "default": "./dist/api.js"
    },
    "./store": {
      "types": "./dist/store/index.d.ts",
      "default": "./dist/store/index.js"
    }
  },
  "scripts": {
    "build": "tsc -b",
    "review-check": "tsx src/precommit.ts",
    "start": "tsx src/server.ts",
    "test": "vitest run"
  },
  "dependencies": {
    "@ht6/extraction": "*",
    "@ht6/ingestion": "*",
    "@ht6/shared": "*",
    "@ht6/pipeline": "*",
    "@modelcontextprotocol/sdk": "^1.0.0",
    "pg": "^8.22.0",
    "zod": "^3.25.0"
  },
  "devDependencies": {
    "@types/pg": "^8.20.0"
  }
}
